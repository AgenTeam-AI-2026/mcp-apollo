{
  "name": "mcp-apollo",
  "version": "0.1.0",
  "description": "An open-source MCP server for Apollo.io — built for AgenTeam",
  "license": "MIT",
  "private": false,
  "main": "dist/index.js",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc --noEmit && wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250409.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.1.1",
    "eslint": "^9.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1",
    "wrangler": "^4.10.0"
  }
}
